{
  "expo": {
    "name": "Sureva",
    "slug": "App",
    "scheme": "sureva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rohitdodda.sureva",
      "icon": "./assets/icon.png"
    },
    "android": {
      "package": "com.rohitdodda.sureva",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FD7A02"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sureva uses your location to detect your environment (beach, snow, urban, etc.) so UV reflection is calculated accurately."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sureva needs access to your photos to update your profile picture.",
          "cameraPermission": "Sureva needs your camera to take a profile photo."
        }
      ],
      "expo-video",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Sureva uses Face ID to confirm it's really you before deleting your account."
        }
      ],
      "expo-live-activity",
      "./withoutPushEntitlement.js"
    ]
  }
}
